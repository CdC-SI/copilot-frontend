        ]
      },
      "retrieval": {
        "title": "Suche nach Dokumenten",
        "tips": [
          "Stellen Sie Ihre Fragen zu einem bestimmten Thema",
          "Wenn der Kopilot Schwierigkeiten hat zu antworten, filtern Sie die Quelle und die Tags manuell",
          "Hinweis: Diese Filterung wird bald automatisiert"
        ]
      },
      "document_management": {
        "title": "Verwaltung von Dokumenten",
        "tips": [
          "Laden Sie PDFs mithilfe der Download-Schaltfläche herunter",
          "Stellen Sie dann Ihre Fragen zu den heruntergeladenen Dokumenten",
          "Übersetzen oder fassen Sie heruntergeladene Dokumente zusammen",
          "Die Dokumente bleiben 24 Stunden lang verfügbar"
        ]
      },
      "advanced_options": {
        "title": "Erweiterte Optionen",
        "tips": [
          "Stellen Sie das Sprachmodell im Abschnitt 'Erweiterte LLM-Einstellungen' ein",
